# ============================================
# Core-CBT 공용 환경변수 (Next.js + FastAPI)
# ============================================
# 이 파일을 복사해서 .env 를 만드세요:  cp .env.example .env

# --- Next.js (next-auth) ---
NEXTAUTH_SECRET=dev-fallback-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_PW=

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Supabase ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- FastAPI Agent 서버 ---
AGENT_API_URL=http://localhost:8001

# --- FastAPI Agent 전용 ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
INTERNAL_SHARED_SECRET=generate-a-long-random-string-here
DATASETS_ROOT=./datasets/practicalIndustrial
AGENT_MAX_ITERATIONS=5
AGENT_RATE_LIMIT_PER_HOUR=20

# Optional: Supabase 테이블명 오버라이드 (기본값 그대로 쓰면 생략 가능)
# SUPABASE_EVENTS_TABLE=analytics_events
# SUPABASE_PROBLEM_OUTCOMES_TABLE=problem_outcomes
# SUPABASE_AGENT_SESSIONS_TABLE=agent_sessions
# SUPABASE_GPT_CACHE_TABLE=gpt_objection_cache

# --- Analytics / Discord ---
# DISCORD_REPORT_WEBHOOK_URL=
# ADMIN_DASHBOARD_URL=

# --- Feature flags ---
# REQUIRE_LOGIN_FOR_PROTECTED_ROUTES=0
